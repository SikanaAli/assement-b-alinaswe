{
  "name": "submission-approval-workflow-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prisma:generate": "dotenv -e ../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "prisma:seed": "dotenv -e ../.env -- ts-node --project tsconfig.json prisma/seed.ts",
    "test": "jest --runInBand",
    "test:e2e": "dotenv -e ../.env -- jest --config ./jest.e2e.config.js --runInBand",
    "start": "node dist/main.js",
    "start:dev": "ts-node --project tsconfig.json src/main.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^6.10.1",
    "@scalar/nestjs-api-reference": "^1.2.5",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^7.4.4",
    "jest": "^29.7.0",
    "prisma": "^6.10.1",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
