generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  APPLICANT
  REVIEWER
}

enum Status {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  RETURNED
}

enum Category {
  GENERAL
  FINANCE
  HR
  IT
}

model User {
  id                String        @id @default(uuid()) @db.Uuid
  name              String
  email             String        @unique
  passwordHash      String
  role              Role
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  ownedApplications Application[] @relation("ApplicationOwner")
  auditLogs         AuditLog[]    @relation("AuditLogActor")
}

model Application {
  id          String     @id @default(uuid()) @db.Uuid
  ownerId     String     @db.Uuid
  owner       User       @relation("ApplicationOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  title       String
  category    Category
  description String?
  amount      Decimal?   @db.Decimal(12, 2)
  status      Status     @default(DRAFT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  auditLogs   AuditLog[]

  @@index([ownerId])
}

model AuditLog {
  id            String      @id @default(uuid()) @db.Uuid
  applicationId String      @db.Uuid
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actorId       String      @db.Uuid
  actor         User        @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: Restrict)
  oldStatus     Status
  newStatus     Status
  comment       String?
  createdAt     DateTime    @default(now())

  @@index([applicationId])
  @@index([actorId])
}
